{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug TinyML Tests",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/TinyML/build/tests.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/TinyML",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb", // or the full path to your gdb.exe if needed
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}